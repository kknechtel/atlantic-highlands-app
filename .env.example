# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/atlantic_highlands

# AWS
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=atlantic-highlands-documents
# Optional: pull all secrets from AWS Secrets Manager instead of from this
# file. Note that config.py's _get() gives AWS precedence over env vars,
# so if the named secret contains DATABASE_URL, it overrides the value above.
# Safer to leave blank in local dev and only set this in deployed environments.
AWS_SECRETS_NAME=

# AI / LLM
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
# Voyage AI (semantic embeddings, voyage-3, 1024-dim). Without this the
# system falls back to deterministic SHA-512 hash vectors — keyword search
# still works via tsvector but recall on chat/RAG queries degrades.
VOYAGE_API_KEY=
# Optional cloud fallback for meeting-recording transcription when local
# faster-whisper fails (decoder errors, OOM, etc.). Leave blank to disable.
OPENAI_API_KEY=
# Whisper model size: tiny | base | small (default: base). Smaller = faster
# but lower quality. Affects /api/meetings/{id}/transcribe.
WHISPER_MODEL=base

# Auth
SECRET_KEY=change-me-in-production
JWT_SECRET=change-me-in-production

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8001
