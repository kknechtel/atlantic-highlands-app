# Atlantic Highlands API — environment template
# Copy to .env and fill in. .env is gitignored.

# ─── Required ─────────────────────────────────────────────────────────

# Postgres connection — must be a pgvector-capable instance for semantic search.
# Local dev default port is 5433 (the docker-compose convention).
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/atlantic_highlands

# JWT signing key. Use a strong random value in production.
SECRET_KEY=change-me-in-production
JWT_SECRET=

# CORS — comma-separated. Add the deployed frontend origin in production.
ALLOWED_ORIGINS=http://localhost:3000

# ─── AI / LLM ─────────────────────────────────────────────────────────

# Anthropic — primary LLM. Required for chat with thinking, fact-check,
# deck-aware AI proposals, financial drill agents.
# https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Google Gemini — used as a fallback for chat and as the cheap path in
# the financial extractor (tries Gemini first, then Claude).
# https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Voyage AI — embeddings for semantic document search. Without this,
# the system falls back to deterministic hash vectors (still works for
# keyword search via tsvector, but no semantic recall).
# Free tier covers ~50M tokens/mo, plenty for the AH document corpus.
# https://dash.voyageai.com/
VOYAGE_API_KEY=

# ─── AWS (S3 storage + optional Secrets Manager) ─────────────────────

AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=atlantic-highlands-documents

# Optional: set this to load all of the above from AWS Secrets Manager
# instead of env vars. The secret should be a JSON object with the same
# keys as above.
# AWS_SECRETS_NAME=atlantic-highlands/api

# ─── Misc ─────────────────────────────────────────────────────────────

DEBUG=false
JWT_EXPIRATION_HOURS=24
